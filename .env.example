# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mindlink

# Redis
REDIS_URL=redis://localhost:6379

# AI Providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# Auth
NEXTAUTH_SECRET=your-secret-here
