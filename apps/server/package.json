{
  "name": "@mindlink/server",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsup src/index.ts --format esm --clean",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "ws:dev": "tsx watch src/yjs/websocket-server.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@hono/node-server": "^1.12.0",
    "@mindlink/types": "workspace:*",
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.34.8",
    "groq-sdk": "^0.9.1",
    "hono": "^4.4.0",
    "ioredis": "^5.4.1",
    "jose": "^5.9.6",
    "openai": "^4.77.0",
    "ws": "^8.18.0",
    "y-protocols": "^1.0.6",
    "y-websocket": "^2.0.4",
    "yjs": "^13.6.20"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.13",
    "prisma": "^5.22.0",
    "tsup": "^8.1.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5"
  }
}
